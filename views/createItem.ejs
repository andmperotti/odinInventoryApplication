<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Inventory</h1>
    <a href="/">Homepage</a>
    <h2>New Item</h2>
    <form action="/items/createItem%>" method="post">
      <label>Name: <input name="itemName" required minlength="1"></label>
    <label style="display: block">
      Quantity
      <input type="number" min="0" required name="itemQuantity" value="1"/>
    </label>
    <label style="display: block">
      Price
      <input required type="number" min="1" name="itemPrice" value="1"/>
    </label>
    <label
      >Categories:
      <select name="itemCategoryId" id="category-select"  required >
        <%categories.rows.forEach(category=>{ %>
          <option value="<%=category.id%>" <%=category.id==categoryId ? "selected": "" %>>
            <%=category.name%>
          </option>
        <%})%>
      </select>

    </label>
    <button style="display: block; margin-top: 1%">Create Item</button>
    </form>

  </body>
</html>
