<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Inventory</h1>
    <a href="/">Homepage</a>
    <h2><%=item.name%>:</h2>
    <form action="/items/updateItem/<%=item.id%>" method="post">
      <label>Name: <input value="<%=item.name%>" name="itemName" required minlength="1"></label>
    <label style="display: block">
      Quantity
      <input value="<%=item.quantity%>" type="number" min="0" required name="itemQuantity"/>
    </label>
    <label style="display: block">
      Price
      <input value="<%=item.price%>" required type="number" min="1" name="itemPrice"/>
    </label>
    <label
      >Categories:
      <select name="itemCategoryIds" id="category-select" multiple  >
        <%categories.rows.forEach(category=>{ %>
          <option 
            value="<%=category.id%>"
            <%=item.categoryids? item.categoryids.includes(category.id)? 'selected' : '' : ''%> >
            <%=category.name%>
          </option>
        <%})%>
      </select>
      <span style="display: block;">To select multiple categories hold command(mac), or control(windows) while clicking categories for the item. To unselect a category hold the same key and click on the category you'd like to remove.</span>
    </label>
    <button style="display: block; margin-top: 1%">Update</button>
    </form>
    <button
      style="background-color: red; display: block; margin-top: 10%">
      DELETE ITEM
    </button>

    <script src="../js/main.js"></script>
  </body>
</html>
