<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Inventory</h1>
    <a href="/">Homepage</a>
    <h2><%=item.name%>:</h2>
    <form action="/items/updateItem/<%=item.id%>" method="post">
      <label>Name: <input value="<%=item.name%>" name="itemName" required minlength="1"></label>
    <label style="display: block">
      Quantity
      <input value="<%=item.quantity%>" type="number" min="0" required name="itemQuantity"/>
    </label>
    <label style="display: block">
      Price
      <input value="<%=item.price%>" required type="number" min="1" name="itemPrice"/>
    </label>
    <label
      >Categories:
      <select name="itemCategoryId" id="category-select" required >
        <%categories.rows.sort((a,b)=>a.id-b.id).forEach(category=>{ %>
          <option value="<%=category.id%>" <%=category.id===item.categoryid ? 'selected' : ''%> >
            <%=category.name%>
          </option>
        <%})%>
      </select>
    </label>
    <button style="display: block; margin-top: 1%">Update</button>
    </form>
    <form action="/items/deleteItem/<%=item.id%>" method="post"  >
      <button
        style="background-color: red; display: block; margin-top: 10%">
        DELETE ITEM
      </button>
    </form>

  </body>
</html>
